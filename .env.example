# URL backend CampusCore, tanpa slash di bagian akhir.
VITE_API_BASE_URL=http://localhost:8000/api

# Fingerprint aplikasi yang harus cocok dengan allow-rule Cloudflare.
VITE_API_SERVICE_NAME=

# Identitas aplikasi yang ditampilkan pada UI.
VITE_APP_NAME=CampusCore
VITE_APP_LONG_NAME=Sistem Informasi Kampus Terpadu

# Tema awal antarmuka. Nilai tidak valid akan menggunakan default di bawah.
VITE_THEME_PRIMARY=blue
VITE_THEME_SURFACE=slate
VITE_THEME_PRESET=Aura
VITE_THEME_MENU_MODE=static
